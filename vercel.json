{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-products",
      "schedule": "0 0 * * *"
    }
  ]
}
